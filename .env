# Production
DATABASE_URL="file:./marketplace.db"
NEXT_PUBLIC_SITE_URL="https://cortexprism.io"
NEXT_PUBLIC_GITHUB_REPO="CortexPrism/cortex"

# Development overrides (uncomment for local dev):
# NEXT_PUBLIC_SITE_URL="http://localhost:3000"
JWT_SECRET=change-this-to-a-random-secret-in-production

# GitHub API token (optional but recommended for topic scanning):
# Create at https://github.com/settings/tokens (scopes: public_repo)
# Without this, GitHub API rate limits are 60 req/hr (vs 5000 req/hr with token)
# GITHUB_TOKEN=ghp_your_token_here
